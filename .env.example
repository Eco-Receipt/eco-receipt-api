# ── Monad / EVM ──────────────────────────────────────────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143
CONTRACT_ADDRESS=0xYourDeployedContractAddress
PRIVATE_KEY=0xYourPrivateKeyHere

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AI_MODE=mock to skip real API calls (great for demo without keys)
# Set AI_MODE=openai to use OpenAI GPT
AI_MODE=mock

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Storage ───────────────────────────────────────────────────────────────────
# local  → save to app/data/  (default, no external deps)
# ipfs   → reserved for future IPFS/Pinata integration
STORAGE_BACKEND=local

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
